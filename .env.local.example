# Copy to .env.local and fill from your Supabase project
# (Dashboard -> Project Settings -> Data API for URL + anon key,
#  Dashboard -> Project Settings -> API Keys for the service_role key).

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SERVER ONLY — never expose to the client).
# Used by route handlers; this app enforces access in code, not via RLS.
SUPABASE_SERVICE_ROLE_KEY=
